{
  "name": "hakanai-client-tests",
  "version": "1.0.0",
  "description": "Unit tests for Hakanai TypeScript client",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "testEnvironmentOptions": {
      "url": "https://localhost"
    },
    "setupFiles": [
      "<rootDir>/setup.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/setup.js"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "moduleNameMapper": {
      "^\\.\\/(.+)\\.js$": "./$1",
      "^\\.\\./(.+)\\.js$": "../$1"
    }
  }
}
